# Project configuration
PROJECT_NAME="ClimateTwin India"
API_V1_STR="/api/v1"

# CORS Configuration (comma-separated origins)
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:8000,*"

# Database Configuration (Supabase PostgreSQL)
# Option 1: Complete Connection URL (Preferred)
# For Supabase, obtain this from Project Settings -> Database -> Connection string -> URI
DATABASE_URL="postgresql://postgres:your-super-secure-password@db.your-supabase-project-id.supabase.co:5432/postgres"

# Option 2: Individual database parts (Used if DATABASE_URL is not set)
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your-super-secure-password"
POSTGRES_HOST="db.your-supabase-project-id.supabase.co"
POSTGRES_PORT="5432"
POSTGRES_DB="postgres"

# Supabase Auth Configuration
# Obtain these from Project Settings -> API
SUPABASE_URL="https://your-supabase-project-id.supabase.co"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret-from-settings"
SUPABASE_ANON_KEY="your-supabase-anon-key-from-settings"
